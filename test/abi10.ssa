# Test complicated struct passing and return
# Includes mixed types and nesting

type :inner = { w, s }
type :outer = { b 4, :inner, d, l }

function w $check(:outer %o, l %ptr) {
@start
	# Extract values from %o and check them
	# Due to QBE limitations on struct access, we usually pass structs as pointers
	# or use the ABI to load them. Here we test passing by value.

	# Driver will fill outer with:
	# { .b = {1, 2, 3, 4}, .in = { .w = 42, .s = 3.14f }, .d = 2.718, .l = 1234567890 }

	storel 0, %ptr
	ret 0
}

export function $test_complex_abi(:outer %o) {
@start
	%res =w call $cb_complex(:outer %o)
	ret
}

# >>> driver
# #include <stdio.h>
# #include <string.h>
# #include <math.h>
