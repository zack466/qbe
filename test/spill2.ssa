	%u4 =l add %t8, %t9
	%u5 =l add %t10, %t11
	%u6 =l add %t12, %t13
	%u7 =l add %t14, %t15

	%w0 =l add %u0, %u1
	%w1 =l add %u2, %u3
	%w2 =l add %u4, %u5
	%w3 =l add %u6, %u7

	%x0 =l add %w0, %w1
	%x1 =l add %w2, %w3

	%ret =l add %x0, %x1
	ret %ret
